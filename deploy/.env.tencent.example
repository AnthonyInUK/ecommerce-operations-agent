# Tencent Cloud CVM deployment env.
# Copy to project root as .env.tencent, then fill API keys:
#   cp deploy/.env.tencent.example .env.tencent

# Server. Public traffic should use Caddy on 80/443; 18080 is the internal app port.
SERVER_PORT=18080
APP_LOG_LEVEL=INFO

# Recommended default: DeepSeek through Spring AI OpenAI-compatible provider.
MODEL_PROVIDER=deepseek
SPRING_AI_MODEL_CHAT=openai
SPRING_AI_DASHSCOPE_ENABLED=false
MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional DashScope. If you switch to DashScope:
# MODEL_PROVIDER=dashscope
# SPRING_AI_MODEL_CHAT=dashscope
# SPRING_AI_DASHSCOPE_ENABLED=true
# MODEL_NAME=qwen-max
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max

# File-based H2 persistence. Good enough for the first Tencent Cloud demo.
APP_DATASOURCE_URL=jdbc:h2:file:/app/data/ecommerce-agent;MODE=MySQL;AUTO_SERVER=TRUE;DATABASE_TO_UPPER=false
APP_DATASOURCE_USERNAME=sa
APP_DATASOURCE_PASSWORD=

# Demo warehouse bootstrap. Keep true for the ecommerce anomaly demo.
APP_BOOTSTRAP_DEMO_DATA=true

# Olist public dataset import/analytics. Keep false unless you mount a complete dataset.
APP_BOOTSTRAP_OLIST_RAW_SCHEMA=false
APP_OLIST_RAW_IMPORT_DIR=/app/olist-csv
APP_BOOTSTRAP_OLIST_ANALYTICS=false
APP_PREFER_OLIST_ANALYTICS=false

# Manual anomaly trigger is available at:
# POST /api/ecommerce/triggers/gmv-drop-watch/run-once
APP_OPERATIONS_GMV_DROP_WATCH_ENABLED=false
APP_OPERATIONS_GMV_DROP_WATCH_DEMO_REPORT_DATE=2018-08-29
APP_OPERATIONS_GMV_DROP_WATCH_THRESHOLD=0.15
APP_OPERATIONS_GMV_DROP_WATCH_WOW_THRESHOLD=0.15
APP_OPERATIONS_GMV_DROP_WATCH_ROLLING_WINDOW_DAYS=7
APP_OPERATIONS_GMV_DROP_WATCH_ROLLING_THRESHOLD=0.12
APP_OPERATIONS_GMV_DROP_WATCH_YOY_THRESHOLD=0.15
APP_OPERATIONS_DAILY_REPORT_ENABLED=false

# Optional Feishu webhook. Leave empty for log fallback.
FEISHU_WEBHOOK_URL=
FEISHU_NOTIFICATION_DEDUP_ENABLED=true
PERSISTENT_NOTIFICATION_DEDUP_ENABLED=true
NOTIFICATION_FALLBACK_TO_IDE_LOG_ENABLED=true

# Runtime knobs
READ_CACHE_ENABLED=true
READ_CACHE_TTL_SECONDS=120
READ_CACHE_MAX_ENTRIES=512
READ_CACHE_CACHE_EMPTY_RESULTS=false
TRIGGER_TIMEOUT_MS=300000
